{
    "name": "animal-island-ui-tailwind",
    "version": "0.8.0",
    "description": "Tailwind CSS v4 + Radix UI modernization of Animal Island UI",
    "type": "module",
    "main": "dist/cjs/index.cjs",
    "module": "dist/es/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/es/index.js",
            "require": "./dist/cjs/index.cjs"
        },
        "./style": "./dist/index.css",
        "./dist/index.css": "./dist/index.css"
    },
    "files": [
        "dist",
        "AI_USAGE.md",
        "DESIGN_PROMPT.md",
        "README.md",
        "skill"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/lifeodyssey/animal-island-ui"
    },
    "homepage": "https://github.com/lifeodyssey/animal-island-ui#readme",
    "bugs": {
        "url": "https://github.com/lifeodyssey/animal-island-ui/issues"
    },
    "author": "lifeodyssey",
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
        "build:demo": "vite build --config vite.config.demo.ts",
        "storybook": "storybook dev -p 6006",
        "storybook:test": "storybook dev -p 6106 --host 127.0.0.1",
        "build:storybook": "storybook build",
        "test": "npm run test:migration && npm run test-storybook && npm run test:playwright && npm run test:visual",
        "test:ci": "npm run test:migration && npm run test-storybook && npm run test:playwright",
        "test-storybook": "vitest --project=storybook --run",
        "test:playwright": "playwright test tests/playwright-*.spec.ts",
        "test:migration": "node --test tests/migration.test.mjs",
        "test:visual": "playwright test tests/visual-*.spec.ts",
        "codex:upstream-check": "node scripts/check-upstream-sync.mjs",
        "verify": "npm run build && npm pack --dry-run && npm test && npm run build:demo && npm run build:storybook && tsc --noEmit",
        "publish:dry-run": "npm publish --dry-run",
        "prepublishOnly": "npm run build",
        "deploy": "npm run build:demo && gh-pages -d demo-dist"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "dependencies": {
        "@fontsource/noto-sans-sc": "^5.2.9",
        "@fontsource/nunito": "^5.2.7",
        "@fontsource/zen-maru-gothic": "^5.2.8",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "classnames": "^2.5.1",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@laynezh/vite-plugin-lib-assets": "^2.1.3",
        "@playwright/test": "^1.60.0",
        "@storybook/addon-docs": "^10.0.0",
        "@storybook/addon-mcp": "^0.6.0",
        "@storybook/addon-vitest": "^10.4.0",
        "@storybook/react-vite": "^10.0.0",
        "@tailwindcss/vite": "^4.1.0",
        "@types/node": "^25.5.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/browser": "^4.1.6",
        "@vitest/browser-playwright": "^4.1.6",
        "gh-pages": "^6.3.0",
        "glob": "^11.0.1",
        "playwright": "^1.60.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "storybook": "^10.0.0",
        "tailwindcss": "^4.1.0",
        "typescript": "^5.7.3",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.6"
    },
    "keywords": [
        "react",
        "component-library",
        "ui",
        "typescript",
        "theme",
        "animal-island-ui",
        "animal-island-ui-tailwind",
        "tailwindcss",
        "radix-ui",
        "nature"
    ],
    "license": "MIT"
}

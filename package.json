{
  "name": "animal-island-ui-tailwind",
  "version": "1.0.0",
  "description": "Tailwind CSS v4 + Radix UI modernization of Animal Island UI",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./style": "./dist/index.css",
    "./style/core": "./dist/core.css",
    "./style/fonts": "./dist/fonts.css",
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "AI_USAGE.md",
    "DESIGN_PROMPT.md",
    "README.md",
    "skill"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lifeodyssey/animal-island-ui-tailwind"
  },
  "homepage": "https://github.com/lifeodyssey/animal-island-ui-tailwind#readme",
  "bugs": {
    "url": "https://github.com/lifeodyssey/animal-island-ui-tailwind/issues"
  },
  "author": "lifeodyssey",
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "storybook dev -p 6106 --host 127.0.0.1",
    "build:storybook": "storybook build",
    "test": "npm run test:migration && npm run test:unit && npm run test-storybook && npm run test:playwright && npm run test:visual",
    "test:ci": "npm run test:migration && npm run test:unit && npm run test-storybook && npm run test:playwright && npm run test:a11y",
    "test-storybook": "vitest --project=storybook --run",
    "test:playwright": "playwright test tests/playwright-*.spec.ts",
    "test:migration": "node --test tests/migration.test.mjs",
    "test:visual": "playwright test tests/visual-*.spec.ts",
    "test:visual-baseline": "playwright test tests/visual-*.spec.ts --update-snapshots",
    "test:visual-check": "playwright test tests/visual-*.spec.ts",
    "test:a11y": "playwright test tests/a11y-axe.spec.ts",
    "test:coverage": "vitest --project=storybook --run --coverage",
    "test:unit": "vitest --project=unit --run",
    "upstream:delta": "node scripts/upstream-delta.mjs",
    "codex:upstream-check": "node scripts/check-upstream-sync.mjs",
    "verify": "npm run build && npm pack --dry-run && npm test && npm run build:storybook && tsc --noEmit",
    "publish:dry-run": "npm publish --dry-run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.0",
    "@radix-ui/react-switch": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "gsap": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-accordion": {
      "optional": true
    },
    "@radix-ui/react-checkbox": {
      "optional": true
    },
    "@radix-ui/react-dialog": {
      "optional": true
    },
    "@radix-ui/react-radio-group": {
      "optional": true
    },
    "@radix-ui/react-select": {
      "optional": true
    },
    "@radix-ui/react-switch": {
      "optional": true
    },
    "@radix-ui/react-tabs": {
      "optional": true
    },
    "@radix-ui/react-tooltip": {
      "optional": true
    },
    "gsap": {
      "optional": true
    }
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react-vite": "^10.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-istanbul": "^4.1.6",
    "glob": "^11.0.1",
    "gsap": "^3.15.0",
    "jsdom": "^29.1.1",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "react",
    "component-library",
    "ui",
    "typescript",
    "theme",
    "animal-island-ui",
    "animal-island-ui-tailwind",
    "tailwindcss",
    "radix-ui",
    "nature"
  ],
  "license": "MIT",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
